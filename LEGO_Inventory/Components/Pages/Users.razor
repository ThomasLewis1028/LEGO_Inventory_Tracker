@page "/users"
@inject IDbContextFactory<InventoryContext> DbContextFactory
@inject ImageStorageService ImageStorage
@using LEGO_Inventory.Database
@using Color = MudBlazor.Color
@rendermode InteractiveServer
@attribute [Authorize]

<PageTitle>Users</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Users</MudText>

@if (_isLoading)
{
    <div style="display: flex; justify-content: center; align-items: center; height: 60vh;">
        <MudProgressCircular Indeterminate="true" Size="Size.Large"/>
    </div>
    return;
}

<MudPaper Elevation="2">
    <MudDataGrid T="UserRow" Items="@_rows" SortMode="SortMode.Multiple" QuickFilter="FilterFunc">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Users</MudText>
            <MudSpacer/>
            <MudTextField @bind-Value="_search" Placeholder="Search" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                          Immediate="true" Class="mt-0"/>
        </ToolBarContent>
        <Columns>
            <TemplateColumn Title="Avatar" Sortable="false">
                <CellTemplate>
                    <MudAvatar Style="width: 36px; height: 36px;">
                        @if (context.Item.User.ProfilePictureUrl != null)
                        {
                            <MudImage Src="@ImageStorage.ResolveUrl(@context.Item.User.ProfilePictureUrl)" Style="width: 100%; height: 100%; object-fit: cover;"/>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Person"/>
                        }
                    </MudAvatar>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.User.UserId" Title="ID"/>
            <PropertyColumn Property="x => x.User.UserName" Title="Username"/>
            <TemplateColumn Title="Sets" SortBy="x => x.OwnedSets">
                <CellTemplate>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.ViewModule" Size="Size.Small" Style="opacity: 0.5;"/>
                        <MudText>@context.Item.OwnedSets</MudText>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Bricks" SortBy="x => x.OwnedBricks">
                <CellTemplate>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" Style="opacity: 0.5;"/>
                        <MudText>@context.Item.OwnedBricks</MudText>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Minifigs" SortBy="x => x.OwnedMinifigs">
                <CellTemplate>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Style="opacity: 0.5;"/>
                        <MudText>@context.Item.OwnedMinifigs</MudText>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="UserRow"/>
        </PagerContent>
    </MudDataGrid>
</MudPaper>

@code {
    private List<UserRow> _rows = [];
    private string _search = string.Empty;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbContextFactory.CreateDbContext();

        var setCounts = (await context.Set<SetOwned>().AsNoTracking().ToListAsync())
            .GroupBy(so => so.UserId)
            .ToDictionary(g => g.Key, g => g.Count());

        var brickCounts = (await context.Set<BrickOwned>().AsNoTracking().ToListAsync())
            .GroupBy(bo => bo.UserId)
            .ToDictionary(g => g.Key, g => g.Sum(bo => bo.Stock));

        var minifigCounts = (await context.Set<MinifigOwned>().AsNoTracking().ToListAsync())
            .GroupBy(mo => mo.UserId)
            .ToDictionary(g => g.Key, g => g.Sum(mo => mo.Stock));

        _rows = (await context.Users.AsNoTracking().OrderBy(u => u.UserName).ToListAsync())
            .Select(u => new UserRow
            {
                User = u,
                OwnedSets     = setCounts.GetValueOrDefault(u.UserId, 0),
                OwnedBricks   = brickCounts.GetValueOrDefault(u.UserId, 0),
                OwnedMinifigs = minifigCounts.GetValueOrDefault(u.UserId, 0)
            })
            .ToList();

        _isLoading = false;
    }

    private bool FilterFunc(UserRow row) =>
        string.IsNullOrWhiteSpace(_search) ||
        row.User.UserName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        row.User.UserId.ToString().Contains(_search);

    private class UserRow
    {
        public User User { get; set; }
        public int OwnedSets { get; set; }
        public int OwnedBricks { get; set; }
        public int OwnedMinifigs { get; set; }
    }
}
