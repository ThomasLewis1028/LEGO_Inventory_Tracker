@code {
    private string? _setId;
    private List<Set>? _sets;
    private string searchString;
    MudForm form;

    protected override async Task OnInitializedAsync()
    {
        var logger = LoggerFactory.CreateLogger<Sets>();
        logger.LogTrace("Loading Sets");
        using (var context = new InventoryContext())
        {
            var setContext = context.Set<Set>();

            _sets = setContext.ToList();
        }
        
        StateHasChanged();
        logger.LogTrace("Loading Sets Complete");
    }

    private void ImportSet()
    {
        ImportData importData = new ImportData();

        importData.ImportSetInfo(_setId);
        importData.ImportSetParts(_setId);


        OnInitializedAsync();
    }

    private bool SetFilterFunc(Set set) => SetFilter(set, searchString);

    private bool SetFilter(Set set, string searchString)
    {
        if (string.IsNullOrWhiteSpace(this.searchString))
            return true;
        if (set.SetId.Contains(this.searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (set.Name.Contains(this.searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }
    
    // events
    void CommittedItemChanges(Set set)
    {
        using (var context = new InventoryContext())
        {
            var sets = context.Set<Set>();
            
            Set temp = sets.First(s => s == set);

            temp.OwnCount = set.OwnCount;
            temp.BuildCount = set.BuildCount;

            context.SaveChanges();
        }
    }

}