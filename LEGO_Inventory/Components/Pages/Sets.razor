@page "/sets"
@inject ILoggerFactory LoggerFactory
@inject IDialogService DialogService
@inject IJSRuntime JsRuntime
@inject AuthService AuthService
@using LEGO_Inventory.Components.Objects
@using LEGO_Inventory.Database
@using LEGO_Inventory.Services
@using Color = MudBlazor.Color
@rendermode InteractiveServer

<PageTitle>Sets</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Sets</MudText>

<MudGrid>
    @* Stats *@
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_totalSets</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Sets in Catalog</MudText>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_totalOwnedInstances</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Owned Instances</MudText>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_totalOwners</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Collectors</MudText>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_totalPieces.ToString("N0")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Total Pieces</MudText>
            </MudStack>
        </MudPaper>
    </MudItem>

    @* Grid *@
    <MudItem xs="12">
        <MudDataGrid T="SetCatalogRow" Items="@_rows.OrderBy(r => r.Set.SetId)"
                     SortMode="@SortMode.Multiple" QuickFilter="FilterFunc" ReadOnly="true">
            <ToolBarContent>
                <MudText Typo="Typo.h6">All Sets</MudText>
                <MudSpacer/>
                <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start"
                              Immediate="true" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"/>
            </ToolBarContent>
            <Columns>
                <TemplateColumn Title="Image" Editable="false">
                    <CellTemplate>
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center">
                            <MudImage class="cursor-pointer rounded-3" Elevation="2"
                                      Src="@context.Item.Set.SetImg" Height="50"
                                      @onclick="() => OpenImagePopup(context.Item.Set.SetId, context.Item.Set.Name, context.Item.Set.SetImg)"/>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Set.SetId" Title="Id" Editable="false"/>
                <PropertyColumn Property="x => x.Set.Name" Title="Name" Editable="false"/>
                <PropertyColumn Property="x => x.Set.ReleaseYear" Title="Year" Editable="false"/>
                <PropertyColumn Property="x => x.Set.NumBricks" Title="Pieces" Editable="false"/>
                <TemplateColumn Title="Owned" Editable="false" SortBy="x => x.UserOwnedCount">
                    <CellTemplate>
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                           Size="Size.Small"
                                           Disabled="@(context.Item.UserOwnedCount == 0 || AuthService.CurrentUser == null)"
                                           OnClick="() => DecrementOwned(context.Item)"/>
                            <MudText Style="min-width: 20px; text-align: center;">@context.Item.UserOwnedCount</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                           Size="Size.Small"
                                           Disabled="@(AuthService.CurrentUser == null)"
                                           OnClick="() => IncrementOwned(context.Item)"/>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Manual" Editable="false">
                    <CellTemplate>
                        <MudImage @onclick="() => OpenBuildingInstructions(context.Item.Set.ManualUrl)"
                                  class="cursor-pointer rounded-2" Elevation="2" Height="30"
                                  Src="https://logodownload.org/wp-content/uploads/2017/04/lego-logo.png"/>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="SetCatalogRow"/>
            </PagerContent>
        </MudDataGrid>
    </MudItem>
</MudGrid>

@code {
    private List<SetCatalogRow> _rows = [];
    private string _searchString = "";
    private int _totalSets;
    private int _totalOwnedInstances;
    private int _totalOwners;
    private int _totalPieces;

    protected override async Task OnInitializedAsync()
    {
        using var context = new InventoryContext();
        var userId = AuthService.CurrentUser?.UserId;

        var sets = context.Set<Set>().ToList();
        var ownedCounts = context.Set<SetOwned>()
            .Where(so => userId.HasValue && so.UserId == userId.Value)
            .GroupBy(so => so.SetId)
            .ToDictionary(g => g.Key, g => g.Count());

        _rows = sets.Select(s => new SetCatalogRow
        {
            Set = s,
            UserOwnedCount = ownedCounts.GetValueOrDefault(s.SetId, 0)
        }).ToList();

        _totalSets = sets.Count;
        _totalOwnedInstances = context.Set<SetOwned>().Count();
        _totalOwners = context.Set<SetOwned>().Select(so => so.UserId).Distinct().Count();
        _totalPieces = sets.Sum(s => s.NumBricks);

        StateHasChanged();
    }

    private async Task IncrementOwned(SetCatalogRow row)
    {
        if (AuthService.CurrentUser == null) return;

        var importData = new ImportData();
        await importData.AddOwnedSet(row.Set.SetId, AuthService.CurrentUser.UserId);

        row.UserOwnedCount++;
        _totalOwnedInstances++;
        StateHasChanged();
    }

    private async Task DecrementOwned(SetCatalogRow row)
    {
        if (AuthService.CurrentUser == null || row.UserOwnedCount == 0) return;

        using var context = new InventoryContext();
        var userId = AuthService.CurrentUser.UserId;

        var toRemove = context.Set<SetOwned>()
            .Where(so => so.UserId == userId && so.SetId == row.Set.SetId)
            .OrderByDescending(so => so.SetIndex)
            .FirstOrDefault();

        if (toRemove == null) return;

        var deleteData = new DeleteData();
        deleteData.DeleteOwnedSetInfo(userId, row.Set.SetId, toRemove.SetIndex);

        row.UserOwnedCount--;
        _totalOwnedInstances--;
        StateHasChanged();
    }

    private bool FilterFunc(SetCatalogRow row)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        if (row.Set.SetId.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (row.Set.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    }

    private Task OpenImagePopup(string setId, string setName, string? setImgUrl)
    {
        var parameters = new DialogParameters<ImagePopup>
        {
            { x => x._id, setId },
            { x => x._name, setName },
            { x => x._imgUrl, setImgUrl }
        };
        return DialogService.ShowAsync<ImagePopup>("Image Popup", parameters,
            new DialogOptions { CloseOnEscapeKey = true, BackdropClick = true });
    }

    private void OpenBuildingInstructions(string url)
    {
        JsRuntime.InvokeVoidAsync("open", url, "_blank");
    }

    private class SetCatalogRow
    {
        public Set Set { get; set; }
        public int UserOwnedCount { get; set; }
    }
}
