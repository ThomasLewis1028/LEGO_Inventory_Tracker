@page "/sets"
@using System.Text.Json.Nodes
@rendermode InteractiveServer
@inject IHttpClientFactory ClientFactory

<PageTitle>Sets</PageTitle>

<h1>Sets</h1>


<form method="post" @onsubmit="ImportSet" @formname="setimport">
    <AntiforgeryToken/>
    <div>
        <label>
            <InputText @bind-Value="_setId"/>
        </label>
    </div>
    <div>
        <button type="submit">Import</button>
    </div>
</form>

@code {
    private string? _setId;
    JsonObject? _set;

    private async Task ImportSet()
    {
        ImportData importData = new ImportData();

        var temp = importData.ImportSetInfo(_setId);

        if (!temp)
        {
            throw new Exception("No set found");
        }

        if (!importData.ImportSetParts(_setId))
        {
            throw new Exception("No set found");
        }
    }

}