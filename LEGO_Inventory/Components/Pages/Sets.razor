@page "/sets"
@inject ILoggerFactory LoggerFactory
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@using LEGO_Inventory.Components.Objects
@using LEGO_Inventory.Database
@using Color = MudBlazor.Color
@rendermode InteractiveServer

<PageTitle>Sets</PageTitle>

<h1>Sets</h1>

<MudGrid>
    <MudItem xs="12">
        <MudTextField xs="6" T="String" Label="Set ID" Required="true" @bind-Value="_setId" Immediate="true"
                      OnKeyDown="OnKeyDown"/>
        <MudButton xs="6" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => ImportSet())">Import Set
        </MudButton>
    </MudItem>

    @* <MudProgressLinear Value="@setData.Count" Max="@_importSize"/> *@

    <MudItem xs="12">
        <MudDataGrid T="SetInfo" Items="@_setInfos.OrderBy(b => b.Set.SetId)"
                     SortMode="@SortMode.Multiple" EditMode="DataGridEditMode.Cell"
                     CommittedItemChanges="@CommittedItemChanges" QuickFilter="SetFilterFunc"
                     ReadOnly="false">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Sets</MudText>
                <MudSpacer/>
                <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start"
                              Immediate="true" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                              Class="mt-0"></MudTextField>
            </ToolBarContent>
            <Columns>
                <HierarchyColumn T="SetInfo" ButtonDisabledFunc="@(info => info.OwnedSets.Count < 0)"/>
                <TemplateColumn Title="Image" Editable="false">
                    <CellTemplate>
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center">
                            <MudImage class="cursor-pointer rounded-3" Elevation="2" Src="@context.Item.Set.SetImg"
                                      Height="50"
                                      @onclick="((e) => OpenImagePopup(context.Item.Set.SetId, context.Item.Set.Name, context.Item.Set.SetImg))"/>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Set.SetId" Title="Id" Editable="false"/>
                <PropertyColumn Property="x => x.Set.Name" Title="Name" Editable="false"/>
                <PropertyColumn Property="x => x.Set.ReleaseYear" Title="Year" Editable="false"/>
                <PropertyColumn Property="x => GetSetCount(x.Set)" Title="Count" Editable="false"/>
                <PropertyColumn Property="x => x.Set.NumBricks" Title="Pieces" Editable="false"/>
                <TemplateColumn Title="BoM" Editable="false">
                    <CellTemplate>
                        <MudStack Row>
                            <MudIconButton href=@($"/bom/{context.Item.Set.SetId}") Icon="@Icons.Material.Filled.List"
                                           Variant="Variant.Filled" Color="Color.Primary"
                                           Size="Size.Small"></MudIconButton>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Delete" Editable="false">
                    <CellTemplate>
                        <MudStack Row>
                            <MudIconButton
                                Icon="@Icons.Material.Filled.Delete"
                                Variant="Variant.Filled"
                                Color="Color.Error"
                                Size="Size.Small"
                                OnClick="() => DeleteSet(context.Item.Set.SetId, context.Item.Set.Name, context.Item.Set.SetImg)"/>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Manual" Editable="false">
                    <CellTemplate>
                        <MudStack Row>
                            <MudImage @onclick="() => OpenBuildingInstructions(context.Item.Set.ManualUrl)"
                                      class="cursor-pointer rounded-2" Elevation="2" Height="30"
                                      Src="https://logodownload.org/wp-content/uploads/2017/04/lego-logo.png"/>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>

            <ChildRowContent Context="setContext">
                <MudCard>
                    <MudDataGrid T="SetOwned" Items="setContext.Item.OwnedSets">
                        <Columns>
                            <PropertyColumn Title="Index" Property="x => x.SetIndex"/>
                            <PropertyColumn Title="Stock" Property="x => GetStockCount(x)"/>
                            <PropertyColumn Title="Missing" Property="x => GetMissingPieceCount(x)"/>
                            <TemplateColumn Title="BoM" Editable="false">
                                <CellTemplate>
                                    <MudStack Row>
                                        <MudIconButton href=@($"/bom/{context.Item.SetId}/{context.Item.SetIndex}") Icon="@Icons.Material.Filled.List"
                                                       Variant="Variant.Filled" Color="Color.Primary"
                                                       Size="Size.Small"></MudIconButton>
                                    </MudStack>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Delete" Editable="false">
                                <CellTemplate>
                                    <MudStack Row>
                                        <MudIconButton
                                            Icon="@Icons.Material.Filled.Delete"
                                            Variant="Variant.Filled"
                                            Color="Color.Error"
                                            Size="Size.Small"
                                            OnClick="() => DeleteOwnedSet(context.Item.SetId, context.Item.SetIndex, setContext.Item.Set.Name, setContext.Item.Set.SetImg)"/>
                                    </MudStack>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                </MudCard>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => AddOwnedSet(setContext.Item.Set.SetId)">Add Owned Set</MudButton>
            </ChildRowContent>

            <PagerContent>
                <MudDataGridPager T="SetInfo"/>
            </PagerContent>
        </MudDataGrid>
    </MudItem>
</MudGrid>

@code {
    private string? _setId;
    private List<Set>? _sets;
    private List<SetInfo>? _setInfos = [];
    private string searchString;
    private int _importSize = 0;
    MudForm form;
    // private ObservableCollection<SetData> setData { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var logger = LoggerFactory.CreateLogger<Sets>();
        logger.LogTrace("Loading Sets");
        // setData = new ObservableCollection<SetData>();
        using (var context = new InventoryContext())
        {
            var setContext = context.Set<Set>();
            var ownedSetContext = context.Set<SetOwned>();

            _sets = setContext.ToList();

            foreach (Set set in setContext.ToList())
            {
                _setInfos?.Add(new SetInfo
                {
                    Set = set,
                    OwnedSets = ownedSetContext.Where(so => so.SetId == set.SetId).ToList()
                });
            }
        }

        _setId = "";

        StateHasChanged();
        logger.LogTrace("Loading Sets Complete");
    }

    private void ImportSet()
    {
        ImportData importData = new ImportData();

        List<string> setIdList = _setId.Split(null).ToList();

        _importSize = setIdList.Count;

        importData.ImportAll(setIdList);

        OnInitializedAsync();
    }

    private void AddOwnedSet(string setId)
    {
        ImportData importData = new ImportData();

        importData.AddOwnedSet(setId);

        OnInitializedAsync();
    }

    private void OnKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            ImportSet();
            _setId = "";
            OnInitializedAsync();
        }
    }

    private bool SetFilterFunc(SetInfo setInfo) => SetFilter(setInfo);

    private bool SetFilter(SetInfo setInfo)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (setInfo.Set.SetId.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (setInfo.Set.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private Task OpenImagePopup(string setId, string setName, string? setImgUrl)
    {
        var imagePopup = new DialogOptions { CloseOnEscapeKey = true, BackdropClick = true };

        var parameters = new DialogParameters<ImagePopup>
        {
            { x => x._id, setId },
            { x => x._name, setName },
            { x => x._imgUrl, setImgUrl }
        };

        return DialogService.ShowAsync<ImagePopup>("Image Popup", parameters, imagePopup);
    }

    // events
    void CommittedItemChanges(SetInfo setInfo)
    {
        UpdateData updateData = new UpdateData();

        // updateData.UpdateSet(set);
    }

    private int GetMissingPieceCount(SetOwned setOwned)
    {
        using (var context = new InventoryContext())
        {
            var setBrickContext = context.Set<SetBrick>();

            return setBrickContext
                .Where(sb => sb.SetId == setOwned.SetId && sb.SetIndex == setOwned.SetIndex)
                .Sum(sb => sb.Count - sb.Stock);
        }
    }

    private int GetStockCount(SetOwned setOwned)
    {
        using (var context = new InventoryContext())
        {
            var setBrickContext = context.Set<SetBrick>();

            return setBrickContext
                .Where(sb => sb.SetId == setOwned.SetId && sb.SetIndex == setOwned.SetIndex)
                .Sum(sb => sb.Stock);
        }
    }

    private int GetSetCount(Set set)
    {
        using (var context = new InventoryContext())
        {
            var setOwnedContext = context.Set<SetOwned>();

            return setOwnedContext.Count(so => so.SetId == set.SetId);
        }
    }

    private Task OpenErrorPopup(string errorMessage)
    {
        var errorPopup = new DialogOptions { CloseOnEscapeKey = true, BackdropClick = true };

        var parameters = new DialogParameters<ErrorPopup>
        {
            { x => x._errorMessage, errorMessage }
        };

        return DialogService.ShowAsync<ErrorPopup>("Error Popup", parameters, errorPopup);
    }

