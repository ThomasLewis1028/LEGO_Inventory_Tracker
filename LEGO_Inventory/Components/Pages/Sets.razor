    //     public event PropertyChangedEventHandler PropertyChanged;
    //
    //     private void NotifyPropertyChanged(string propertyName)
    //     {
    //         if (PropertyChanged != null)
    //         {
    //             PropertyChanged(this, new PropertyChangedEventArgs(propertyName));
    //         }
    //     }
    // }
    //
    // public async Task ChangeProgressBar()
    // {
    //     StateHasChanged();
    // }

    private async Task DeleteSet(string setId, string setName, string setImgUrl)
    {
        var deletePopup = new DialogOptions { CloseOnEscapeKey = true, BackdropClick = true };

        var parameters = new DialogParameters<DeletePopup>
        {
            { x => x._id, setId },
            { x => x._name, setName },
            { x => x._imgUrl, setImgUrl }
        };
 
        var dialog = DialogService.Show<DeletePopup>("Delete Popup", parameters, deletePopup);

        var result = await dialog.Result;
        
        if (result.Canceled)
            OnInitializedAsync();
    }

}