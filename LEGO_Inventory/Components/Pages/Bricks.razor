@page "/bricks"
@inject ILoggerFactory LoggerFactory
@inject IDialogService DialogService
@using System.Drawing
@using LEGO_Inventory.Components.Objects
@using LEGO_Inventory.Database
@using Color = MudBlazor.Color
@using BrickColor = Color
@using Size = MudBlazor.Size
@rendermode InteractiveServer

<PageTitle>Bricks</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Bricks</MudText>

<MudGrid>
    <MudItem xs="12">
        <MudDataGrid T="BrickInfo" Items="@_brickInfos.OrderBy(b => b.Brick.PartNum)"
                     SortMode="@SortMode.Multiple" QuickFilter="BrickFilterFunc" ReadOnly="true">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Total Bricks: @_brickInfos.Count</MudText>
                <MudSpacer/>
                <MudText Typo="Typo.h6">Total Stock: @_totalStock</MudText>
                <MudSpacer/>
                <MudText Typo="Typo.h6">Total Needed: @_totalNeeded</MudText>
                <MudSpacer/>
                <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start"
                              Immediate="true" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                              Class="mt-0"/>
            </ToolBarContent>
            <Columns>
                <HierarchyColumn T="BrickInfo" ButtonDisabledFunc="@(info => info.SetCount == 0)"/>
                <TemplateColumn Title="Image" Editable="false">
                    <CellTemplate>
                        <MudStack Row>
                            <MudImage class="cursor-pointer rounded-3" Elevation="2" Src="@context.Item.Brick.PartImg"
                                      Height="50"
                                      @onclick="() => OpenImagePopup(context.Item.Brick.PartNum, context.Item.Brick.Name, context.Item.Brick.PartImg)"/>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Brick.PartNum" Title="Id" Editable="false"/>
                <PropertyColumn Property="x => x.Brick.Name" Title="Name" Editable="false"/>
                <TemplateColumn Title="Color" SortBy="x => x.Brick.ColorId" Sortable="true" Editable="false">
                    <CellTemplate>
                        <MudStack Row>
                            @if (context.Item.Brick.HexColor != null)
                            {
                                <MudChip OnClick="() => OpenColorPopup(context.Item.Brick.HexColor, context.Item.Brick.ColorName)"
                                         class="mud-elevation-2"
                                         Style="@ColorChipStyle(context.Item.Brick.HexColor, context.Item.Brick.ColorName)">
                                    @context.Item.Brick.ColorName
                                </MudChip>
                            }
                            else
                            {
                                <MudChip Color="default">N/A</MudChip>
                            }
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.TotalStock" Title="Stock" Editable="false"/>
                <PropertyColumn Property="x => x.TotalNeeded" Title="Needed" Editable="false"/>
                <PropertyColumn Property="x => x.SetCount" Title="Sets" Editable="false"/>
            </Columns>

            <ChildRowContent Context="brickContext">
                <div class="child-row-content">
                @if (!brickContext.Item.IsLoaded)
                {
                    <MudText>Loading sets...</MudText>
                    { _ = LoadSetBricksAsync(brickContext.Item); }
                }
                else if (brickContext.Item.SetBricks.Any())
                {
                    <MudCard>
                        <MudDataGrid T="Set" Items="GetSets(brickContext.Item.SetIds).OrderBy(s => s.SetId)">
                            <Columns>
                                <TemplateColumn Title="Image">
                                    <CellTemplate>
                                        <MudImage class="cursor-pointer rounded-3" Elevation="2"
                                                  Src="@context.Item.SetImg" Height="50"
                                                  @onclick="() => OpenImagePopup(context.Item.SetId, context.Item.Name, context.Item.SetImg)"/>
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Title="Set Id" Property="x => x.SetId"/>
                                <PropertyColumn Title="Name" Property="x => x.Name"/>
                                <TemplateColumn Title="Needed per Copy">
                                    <CellTemplate>
                                        <MudText>@brickContext.Item.SetBricks.First(sb => sb.SetId == context.Item.SetId).Count</MudText>
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="BoM">
                                    <CellTemplate>
                                        <MudIconButton href="@($"/bom/{context.Item.SetId}")"
                                                       Icon="@Icons.Material.Filled.List"
                                                       Variant="Variant.Filled" Color="Color.Primary"
                                                       Size="Size.Small"/>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    </MudCard>
                }
                </div>
            </ChildRowContent>

            <PagerContent>
                <MudDataGridPager T="BrickInfo"/>
            </PagerContent>
        </MudDataGrid>
    </MudItem>
</MudGrid>

@code {
    private List<BrickInfo> _brickInfos = [];
    private int _totalStock;
    private int _totalNeeded;
    private string searchString = "";

    protected override async Task OnInitializedAsync()
    {
        using var context = new InventoryContext();

        // Aggregate stock: personal BrickOwned + allocated SetBrickOwned, across all users
        var brickOwnedStock = context.Set<BrickOwned>()
            .GroupBy(bo => new { bo.PartNum, bo.ColorId })
            .ToDictionary(g => (g.Key.PartNum, g.Key.ColorId), g => g.Sum(bo => bo.Stock));

        var setBrickOwnedStock = context.Set<SetBrickOwned>()
            .GroupBy(sbo => new { sbo.PartNum, sbo.ColorId })
            .ToDictionary(g => (g.Key.PartNum, g.Key.ColorId), g => g.Sum(sbo => sbo.Stock));

        // Aggregate needed: SetBrick.Count × copies owned, across all users
        var setOwnedCopies = context.Set<SetOwned>()
            .GroupBy(so => so.SetId)
            .ToDictionary(g => g.Key, g => g.Count());

        var setBrickAggregates = context.Set<SetBrick>()
            .ToList()
            .GroupBy(sb => (sb.PartNum, sb.ColorId))
            .ToDictionary(
                g => g.Key,
                g => new
                {
                    TotalNeeded = g.Sum(sb => sb.Count * setOwnedCopies.GetValueOrDefault(sb.SetId, 0)),
                    SetCount = g.Select(sb => sb.SetId).Distinct().Count()
                });

        _brickInfos = context.Set<Brick>().ToList().Select(b =>
        {
            var key = (b.PartNum, b.ColorId);
            var stock = brickOwnedStock.GetValueOrDefault(key, 0)
                      + setBrickOwnedStock.GetValueOrDefault(key, 0);
            setBrickAggregates.TryGetValue(key, out var agg);
            return new BrickInfo
            {
                Brick = b,
                TotalStock = stock,
                TotalNeeded = agg?.TotalNeeded ?? 0,
                SetCount = agg?.SetCount ?? 0
            };
        }).ToList();

        _totalStock = _brickInfos.Sum(b => b.TotalStock);
        _totalNeeded = _brickInfos.Sum(b => b.TotalNeeded);

        StateHasChanged();
    }

    private async Task LoadSetBricksAsync(BrickInfo info)
    {
        if (info.IsLoaded) return;
        await using var context = new InventoryContext();
        info.SetBricks = context.Set<SetBrick>()
            .Where(sb => sb.PartNum == info.Brick.PartNum && sb.ColorId == info.Brick.ColorId)
            .ToList();
        info.SetIds = info.SetBricks.Select(sb => sb.SetId).Distinct().ToList();
        info.IsLoaded = true;
        StateHasChanged();
    }

    private List<Set> GetSets(List<string> setIds)
    {
        using var context = new InventoryContext();
        return context.Set<Set>().Where(s => setIds.Contains(s.SetId)).ToList();
    }

    private bool BrickFilterFunc(BrickInfo b)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (b.Brick.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (b.Brick.PartNum.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (b.Brick.ColorId.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (b.Brick.ColorName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    }

    private Task OpenImagePopup(string id, string name, string? imgUrl) =>
        DialogService.ShowAsync<ImagePopup>("Image Popup",
            new DialogParameters<ImagePopup>
            {
                { x => x._id, id }, { x => x._name, name }, { x => x._imgUrl, imgUrl }
            },
            new DialogOptions { CloseOnEscapeKey = true, BackdropClick = true });

    private Task OpenColorPopup(string hex, string name) =>
        DialogService.ShowAsync<ColorPopup>("Color Popup",
            new DialogParameters<ColorPopup>
            {
                { x => x._hexColor, hex }, { x => x._name, name }
            },
            new DialogOptions { CloseOnEscapeKey = true, BackdropClick = true });

    private string ColorChipStyle(string hex, string name)
    {
        var bg = "#" + hex;
        var fg = IsDark(hex) ? "color: white;" : "color: #202020;";
        return $"background-color: {bg}; {fg} width: -moz-available;";
    }

    private bool IsDark(string hex)
    {
        var c = ColorTranslator.FromHtml($"#{hex}");
        return 0.2126 * c.R + 0.7152 * c.G + 0.0722 * c.B < 128;
    }

    private class BrickInfo
    {
        public Brick Brick { get; set; }
        public int TotalStock { get; set; }
        public int TotalNeeded { get; set; }
        public int SetCount { get; set; }
        public bool IsLoaded { get; set; }
        public List<SetBrick> SetBricks { get; set; } = [];
        public List<string> SetIds { get; set; } = [];
    }
}
