@page "/"
@layout FullPageLayout
@inject NavigationManager Nav
@using LEGO_Inventory.Database
@using LEGO_Inventory.Components.Layout
@using Color = MudBlazor.Color
@rendermode InteractiveServer

<PageTitle>LEGO Inventory</PageTitle>

<div class="landing-page">
    <div class="landing-hero">
        <MudText Typo="Typo.h2" Style="font-weight: 800; letter-spacing: -0.02em;">LEGO Inventory</MudText>
        <MudText Typo="Typo.h6" Style="opacity: 0.55; margin-top: 0.5rem; font-weight: 400;">Your personal collection manager</MudText>
    </div>

    <MudGrid Justify="Justify.Center" Style="max-width: 1100px; width: 100%;">
        <MudItem xs="12" sm="6" lg="3">
            <MudCard Class="landing-card" Elevation="4" @onclick='() => Nav.NavigateTo("/sets")'>
                <div class="card-image-wrapper" style="position: relative;">
                    <MudCardMedia Image="@_setImg" Height="220"/>
                    @if (_setName != null)
                    {
                        <div class="card-info-badge">?</div>
                        <div class="card-name-label">@_setName</div>
                    }
                </div>
                <MudCardContent>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.ViewModule" Color="Color.Primary"/>
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">Sets</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Style="opacity: 0.6; margin-top: 4px;">Browse and manage your LEGO sets</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" lg="3">
            <MudCard Class="landing-card" Elevation="4" @onclick='() => Nav.NavigateTo("/bricks")'>
                <div class="card-image-wrapper" style="position: relative;">
                    <MudCardMedia Image="@_brickImg" Height="220"/>
                    @if (_brickName != null)
                    {
                        <div class="card-info-badge">?</div>
                        <div class="card-name-label">@_brickName</div>
                    }
                </div>
                <MudCardContent>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Category" Color="Color.Primary"/>
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">Bricks</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Style="opacity: 0.6; margin-top: 4px;">Track your individual brick inventory</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" lg="3">
            <MudCard Class="landing-card" Elevation="4" @onclick='() => Nav.NavigateTo("/minifigs")'>
                <div class="card-image-wrapper" style="position: relative;">
                    <MudCardMedia Image="@_minifigImg" Height="220"/>
                    @if (_minifigName != null)
                    {
                        <div class="card-info-badge">?</div>
                        <div class="card-name-label">@_minifigName</div>
                    }
                </div>
                <MudCardContent>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary"/>
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">Minifigs</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Style="opacity: 0.6; margin-top: 4px;">Manage your minifigure collection</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" lg="3">
            <MudCard Class="landing-card" Elevation="4" @onclick='() => Nav.NavigateTo("/bom")'>
                <div class="card-image-wrapper" style="position: relative;">
                    <MudCardMedia Image="@_bomImg" Height="220"/>
                    @if (_bomName != null)
                    {
                        <div class="card-info-badge">?</div>
                        <div class="card-name-label">@_bomName</div>
                    }
                </div>
                <MudCardContent>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.FormatListBulleted" Color="Color.Primary"/>
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">Bill of Materials</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Style="opacity: 0.6; margin-top: 4px;">View missing pieces across your sets</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</div>

@code {
    private string? _setImg;
    private string? _setName;
    private string? _brickImg;
    private string? _brickName;
    private string? _minifigImg;
    private string? _minifigName;
    private string? _bomImg;
    private string? _bomName;

    protected override Task OnInitializedAsync()
    {
        using var context = new InventoryContext();

        var sets = context.Set<Set>().Where(s => s.SetImg != null).ToList();
        if (sets.Count > 0)
        {
            var setPick = sets[Random.Shared.Next(sets.Count)];
            _setImg = setPick.SetImg;
            _setName = setPick.Name;

            var bomPick = sets[Random.Shared.Next(sets.Count)];
            _bomImg = bomPick.SetImg;
            _bomName = bomPick.Name;
        }

        var bricks = context.Set<Brick>().Where(b => b.PartImg != null).ToList();
        if (bricks.Count > 0)
        {
            var brickPick = bricks[Random.Shared.Next(bricks.Count)];
            _brickImg = brickPick.PartImg;
            _brickName = brickPick.Name;
        }

        var minifigs = context.Set<Minifig>().Where(m => m.MinifigImgUrl != null).ToList();
        if (minifigs.Count > 0)
        {
            var minifigPick = minifigs[Random.Shared.Next(minifigs.Count)];
            _minifigImg = minifigPick.MinifigImgUrl;
            _minifigName = minifigPick.MinifigName;
        }

        return Task.CompletedTask;
    }
}
