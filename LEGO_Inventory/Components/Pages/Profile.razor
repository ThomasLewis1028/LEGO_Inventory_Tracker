@page "/profile"
@inject AuthService AuthService
@inject ThemeService ThemeService
@inject PendingAuthService PendingAuth
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@using LEGO_Inventory.Database
@using Color = MudBlazor.Color
@rendermode InteractiveServer

<PageTitle>Profile</PageTitle>

@if (AuthService.CurrentUser == null)
{
    <div style="display: flex; justify-content: center; align-items: center; height: 60vh;">
        <MudText Typo="Typo.h6" Style="opacity: 0.6;">Sign in to view your profile.</MudText>
    </div>
    return;
}

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Profile</MudText>

<MudGrid Spacing="3">

    @* ── Profile header ── *@
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                <MudAvatar Style="width: 64px; height: 64px;">
                    @if (AuthService.CurrentUser.ProfilePictureUrl != null)
                    {
                        <MudImage Src="@AuthService.CurrentUser.ProfilePictureUrl" Alt="avatar" Style="width: 100%; height: 100%; object-fit: cover;"/>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size: 2rem;"/>
                    }
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h5" Style="font-weight: 700;">@AuthService.CurrentUser.UserName</MudText>
                    <MudText Typo="Typo.body2" Style="opacity: 0.55;">User ID: @AuthService.CurrentUser.UserId</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>

    @* ── Change Username ── *@
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
            <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 700;">Change Username</MudText>
            <MudStack Spacing="3">
                <MudTextField T="string" Label="New Username" @bind-Value="_newUsername"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person"
                              Immediate="true"/>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="SaveUsername" Disabled="@string.IsNullOrWhiteSpace(_newUsername)">
                    Save Username
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>

    @* ── Change Password ── *@
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
            <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 700;">Change Password</MudText>
            <MudStack Spacing="3">
                <MudTextField T="string" Label="Current Password" @bind-Value="_currentPassword"
                              Variant="Variant.Outlined"
                              InputType="@(_showCurrent ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showCurrent ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="() => _showCurrent = !_showCurrent"/>
                <MudTextField T="string" Label="New Password" @bind-Value="_newPassword"
                              Variant="Variant.Outlined"
                              InputType="@(_showNew ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showNew ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="() => _showNew = !_showNew"/>
                <MudTextField T="string" Label="Confirm New Password" @bind-Value="_confirmPassword"
                              Variant="Variant.Outlined"
                              InputType="@(_showConfirm ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showConfirm ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="() => _showConfirm = !_showConfirm"
                              Error="@(_newPassword != _confirmPassword && !string.IsNullOrEmpty(_confirmPassword))"
                              ErrorText="Passwords do not match"/>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Lock"
                           OnClick="SavePassword"
                           Disabled="@(!CanSavePassword)">
                    Save Password
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>

    @* ── Linked Accounts ── *@
    @if (PendingAuth.EnabledProviders.Count > 0)
    {
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 700;">Linked Accounts</MudText>
                <MudStack Spacing="2">
                    @foreach (var provider in PendingAuth.EnabledProviders)
                    {
                        var p = provider;
                        var linked = _linkedLogins.Any(l => l.Provider == p);
                        var isLast = !_hasPassword && _linkedLogins.Count <= 1 && linked;
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@ProviderIcon(p)" Size="Size.Small"/>
                            <MudText Style="flex: 1;">@p</MudText>
                            @if (linked)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">Linked</MudChip>
                                <MudTooltip Text="@(isLast ? "Can't unlink your only sign-in method" : "Unlink")">
                                    <MudIconButton Icon="@Icons.Material.Filled.LinkOff"
                                                   Size="Size.Small"
                                                   Disabled="@isLast"
                                                   OnClick="@(() => Unlink(p))"/>
                                </MudTooltip>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Link"
                                           OnClick="@(() => LinkProvider(p))">
                                    Link
                                </MudButton>
                            }
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
    }

    @* ── Theme Color ── *@
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-1" Style="font-weight: 700;">Theme Color</MudText>
            <MudText Typo="Typo.body2" Class="mb-4" Style="opacity: 0.55;">Choose your primary accent color.</MudText>
            <div style="display: flex; flex-wrap: wrap; gap: 12px; align-items: center;">
                @foreach (var swatch in _colorSwatches)
                {
                    var swatch1 = swatch;
                    var activeColor = AuthService.CurrentUser?.PrimaryColor ?? ThemeService.DefaultPrimaryColor;
                    var isSelected = string.Equals(activeColor, swatch1.Hex, StringComparison.OrdinalIgnoreCase);
                    <MudTooltip Text="@swatch1.Name">
                        <div @onclick="() => SelectColor(swatch1.Hex)"
                             style="width: 40px; height: 40px; border-radius: 50%; background: @swatch1.Hex; cursor: pointer;
                                    border: 3px solid @(isSelected ? "white" : "transparent");
                                    box-shadow: @(isSelected ? $"0 0 0 3px {swatch1.Hex}" : "0 2px 6px rgba(0,0,0,0.3)");
                                    transition: transform 0.15s, box-shadow 0.15s;"/>
                    </MudTooltip>
                }
            </div>

            <MudExpansionPanels Class="mt-4" Elevation="0">
                <MudExpansionPanel Text="Custom Color" Style="border: 1px solid rgba(128,128,128,0.2); border-radius: 8px;">
                    <MudStack Spacing="3" AlignItems="AlignItems.Start">
                        <MudStack Row Spacing="3" AlignItems="AlignItems.Center">
                            <input type="color" @bind="_customColorHex"
                                   style="width: 64px; height: 40px; border: none; border-radius: 6px; cursor: pointer; padding: 2px; background: none;"/>
                            <MudTextField T="string" @bind-Value="HexInput" Label="Hex" Variant="Variant.Outlined"
                                          Style="max-width: 130px;" Immediate="true"
                                          Adornment="Adornment.Start" AdornmentText="#"
                                          MaxLength="6"/>
                        </MudStack>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Colorize"
                                   OnClick="ApplyCustomColor">
                            Apply Color
                        </MudButton>
                    </MudStack>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudPaper>
    </MudItem>

    @* ── Profile Picture ── *@
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-1" Style="font-weight: 700;">Profile Picture</MudText>
            <MudText Typo="Typo.body2" Class="mb-4" Style="opacity: 0.55;">Choose a minifigure from your collection.</MudText>

            @if (_minifigs.Count == 0)
            {
                <MudText Typo="Typo.body2" Style="opacity: 0.5;">No minifigures found. Import some sets to unlock profile pictures.</MudText>
            }
            else
            {
                <MudTextField T="string" @bind-Value="_minifigSearch" Placeholder="Search minifigures…"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined" Immediate="true" Class="mb-4"
                              Style="max-width: 340px;"/>

                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(90px, 1fr)); gap: 12px; max-height: 420px; overflow-y: auto; padding: 4px;">
                    @* Clear / no picture option *@
                    <div @onclick="ClearProfilePicture"
                         style="cursor: pointer; border-radius: 12px; padding: 8px; display: flex; flex-direction: column; align-items: center; gap: 6px; border: 2px solid @(AuthService.CurrentUser.ProfilePictureUrl == null ? "var(--mud-palette-primary)" : "transparent"); background: @(AuthService.CurrentUser.ProfilePictureUrl == null ? "color-mix(in srgb, var(--mud-palette-primary) 10%, transparent)" : "transparent"); transition: all 0.15s;">
                        <MudAvatar Style="width: 60px; height: 60px;">
                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="font-size: 1.8rem;"/>
                        </MudAvatar>
                        <MudText Typo="Typo.caption" Style="text-align: center; line-height: 1.2;">None</MudText>
                    </div>

                    @foreach (var fig in FilteredMinifigs)
                    {
                        var fig1 = fig;
                        var isSelected = AuthService.CurrentUser.ProfilePictureUrl == fig1.MinifigImgUrl;
                        <div @onclick="() => SelectProfilePicture(fig1.MinifigImgUrl!)"
                             style="cursor: pointer; border-radius: 12px; padding: 8px; display: flex; flex-direction: column; align-items: center; gap: 6px; border: 2px solid @(isSelected ? "var(--mud-palette-primary)" : "transparent"); background: @(isSelected ? "color-mix(in srgb, var(--mud-palette-primary) 10%, transparent)" : "transparent"); transition: all 0.15s;">
                            <MudImage Src="@fig1.MinifigImgUrl" Alt="@fig1.MinifigName"
                                      Style="width: 60px; height: 60px; object-fit: contain;"/>
                            <MudText Typo="Typo.caption" Style="text-align: center; line-height: 1.2; max-width: 80px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@fig1.MinifigName</MudText>
                        </div>
                    }
                </div>
            }
        </MudPaper>
    </MudItem>

</MudGrid>

@code {
    // Linked accounts
    private List<UserExternalLogin> _linkedLogins = [];
    private bool _hasPassword;

    private record ColorSwatch(string Name, string Hex);

    private readonly List<ColorSwatch> _colorSwatches =
    [
        new("LEGO Red",      "#DA291C"),
        new("Blue",          "#1565C0"),
        new("Green",         "#2E7D32"),
        new("Purple",        "#6A1B9A"),
        new("Orange",        "#E65100"),
        new("Teal",          "#00695C"),
        new("Pink",          "#AD1457"),
        new("Indigo",        "#283593"),
        new("Amber",         "#F57F17"),
        new("Cyan",          "#00838F"),
        new("Brown",         "#4E342E"),
        new("Deep Purple",   "#4527A0"),
    ];

    // Username
    private string _newUsername = string.Empty;

    // Password
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _showCurrent, _showNew, _showConfirm;

    // Custom color picker
    private string _customColorHex = "#DA291C";

    private string HexInput
    {
        get => _customColorHex.TrimStart('#');
        set => _customColorHex = "#" + value.TrimStart('#');
    }

    // Profile picture
    private List<Minifig> _minifigs = [];
    private string _minifigSearch = string.Empty;

    private bool CanSavePassword =>
        !string.IsNullOrEmpty(_currentPassword) &&
        !string.IsNullOrEmpty(_newPassword) &&
        _newPassword == _confirmPassword;

    private IEnumerable<Minifig> FilteredMinifigs => string.IsNullOrWhiteSpace(_minifigSearch)
        ? _minifigs
        : _minifigs.Where(m => m.MinifigName.Contains(_minifigSearch, StringComparison.OrdinalIgnoreCase));

    protected override Task OnInitializedAsync()
    {
        _customColorHex = AuthService.CurrentUser?.PrimaryColor ?? ThemeService.DefaultPrimaryColor;
        _linkedLogins   = AuthService.GetLinkedLogins();
        _hasPassword    = !string.IsNullOrEmpty(AuthService.CurrentUser?.PasswordHash);

        // Show feedback if we just came back from a link flow
        var uri  = new Uri(Nav.Uri);
        var qs   = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (qs["linked"] == "true")
            Snackbar.Add("Account linked successfully.", Severity.Success);
        else if (qs["link_error"] == "already_linked")
            Snackbar.Add("That account is already linked to another user.", Severity.Error);

        using var context = new InventoryContext();
        _minifigs = context.Set<Minifig>()
            .Where(m => m.MinifigImgUrl != null && m.MinifigImgUrl != "")
            .OrderBy(m => m.MinifigName)
            .ToList();
        return Task.CompletedTask;
    }

    private void SaveUsername()
    {
        if (string.IsNullOrWhiteSpace(_newUsername)) return;

        if (AuthService.ChangeUsername(_newUsername))
        {
            Snackbar.Add("Username updated.", Severity.Success);
            _newUsername = string.Empty;
        }
        else
        {
            Snackbar.Add("That username is already taken.", Severity.Error);
        }
    }

    private void SavePassword()
    {
        if (!CanSavePassword) return;

        if (AuthService.ChangePassword(_currentPassword, _newPassword))
        {
            Snackbar.Add("Password updated.", Severity.Success);
            _currentPassword = _newPassword = _confirmPassword = string.Empty;
        }
        else
        {
            Snackbar.Add("Current password is incorrect.", Severity.Error);
        }
    }

    private void SelectProfilePicture(string url)
    {
        AuthService.ChangeProfilePicture(url);
        Snackbar.Add("Profile picture updated.", Severity.Success);
    }

    private void LinkProvider(string provider)
    {
        var userId = AuthService.CurrentUser!.UserId;
        Nav.NavigateTo($"/auth/challenge?provider={provider}&linkUserId={userId}", forceLoad: true);
    }

    private void Unlink(string provider)
    {
        if (AuthService.UnlinkExternalLogin(provider))
        {
            _linkedLogins = AuthService.GetLinkedLogins();
            Snackbar.Add($"{provider} account unlinked.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Cannot unlink your only sign-in method.", Severity.Warning);
        }
    }

    private static string ProviderIcon(string provider) => provider switch
    {
        "Google"    => Icons.Custom.Brands.Google,
        "Microsoft" => Icons.Custom.Brands.Microsoft,
        "Discord"   => Icons.Material.Filled.Chat,
        _           => Icons.Material.Filled.Login
    };

    private void ApplyCustomColor()
    {
        var hex = _customColorHex.StartsWith('#') ? _customColorHex : "#" + _customColorHex;
        SelectColor(hex);
    }

    private void SelectColor(string hex)
    {
        AuthService.ChangeThemeColor(hex);
        ThemeService.SetPrimaryColor(hex);
        Snackbar.Add("Theme color updated.", Severity.Success);
    }

    private void ClearProfilePicture()
    {
        AuthService.ChangeProfilePicture(null);
        Snackbar.Add("Profile picture removed.", Severity.Success);
    }
}
