                @* <HierarchyColumn T="BrickInfo" ButtonDisabledFunc="@(info => info.Sets.Count < 0)"/> *@
                <TemplateColumn Title="Image" Editable="false">
                    <CellTemplate>
                        <MudStack Row>
                            <MudImage class="cursor-pointer" Src="@context.Item.MinifigImgUrl" Height="50"
                                      @onclick="((e) => OpenImagePopup(context.Item.MinifigId, context.Item.MinifigName, context.Item.MinifigImgUrl))"/>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.MinifigId" Title="Set Id" Editable="false"/>
                <PropertyColumn Property="x => x.MinifigName" Title="Name" Editable="false"/>
                @* <TemplateColumn Title="Delete" Editable="false"> *@
