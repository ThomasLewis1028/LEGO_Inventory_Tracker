@code {
    private List<Minifig>? _minifigs;
    private string searchString;
    MudForm form;

    protected override async Task OnInitializedAsync()
    {
        var logger = LoggerFactory.CreateLogger<Minifig>();
        logger.LogTrace("Loading Minifigs");
        using (var context = new InventoryContext())
        {
            var minifigContext = context.Set<Minifig>();

            _minifigs = minifigContext.ToList();
        }

        StateHasChanged();
        logger.LogTrace("Loading Sets Complete");
    }
    

    private bool MinifigFilterFunc(Minifig minifig) => MinifigFilter(minifig);

    private bool MinifigFilter(Minifig minifig)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (minifig.MinifigId.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (minifig.MinifigName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private Task OpenImagePopup(string minifigId, string minifigName, string minifigImgUrl)
    {
        var imagePopup = new DialogOptions { CloseOnEscapeKey = true, BackdropClick = true };

        var parameters = new DialogParameters<ImagePopup>
        {
            { x => x._id, minifigId },
            { x => x._name, minifigName },
            { x => x._imgUrl, minifigImgUrl }
        };

        return DialogService.ShowAsync<ImagePopup>("Image Popup", parameters, imagePopup);
    }

