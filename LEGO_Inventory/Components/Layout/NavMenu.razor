<MudDrawer Open="true" Anchor="Anchor.Start" Width="250px" Height="100%" Class="py-3" Elevation="0"
           Variant="DrawerVariant.Persistent">
    <MudNavMenu Bordered="true" Class="mud-width-full" Rounded="true" Color="Color.Success">
        <MudNavLink Href="/sets" Icon="@Icons.Material.Filled.House">Sets</MudNavLink>
        <MudNavLink Href="/bricks" Icon="@Icons.Material.Filled.Dashboard">Bricks</MudNavLink>
        @* <MudNavLink Href="/setbricks" Icon="@Icons.Material.Filled.Token">Set Bricks</MudNavLink> *@
        <MudNavLink Href="/minifigs" Icon="@Icons.Material.Filled.Person">Minifigs</MudNavLink>
    </MudNavMenu>
</MudDrawer>

@code {
    private bool _collapseNavMenu = true;
    private bool _open = true;
    private string _universeName = "";
    private string _universeId = "";

    private string? NavMenuCssClass => _collapseNavMenu ? "collapse" : null;
   
}