@inherits LayoutComponentBase
@using Color = MudBlazor.Color
@using LEGO_Inventory.Components.Objects
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ThemeService ThemeService
@inject AuthService AuthService
@inject IDialogService DialogService
@inject ProtectedLocalStorage LocalStorage
@implements IDisposable

<PageTitle>LEGO Inventory Tracker</PageTitle>

<MudThemeProvider Theme="ThemeService.Theme" IsDarkMode="@ThemeService.IsDarkMode"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Elevation="2">
        <MudLink Href="/" Typo="Typo.h6" Color="Color.Inherit" Style="font-weight: 700; letter-spacing: 0.04em; text-decoration: none;">LEGO Inventory</MudLink>
        <MudSpacer/>
        <MudTooltip Text="@(ThemeService.IsDarkMode ? "Light Mode" : "Dark Mode")">
            <MudIconButton Icon="@(ThemeService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" OnClick="@ThemeService.ToggleDarkMode"/>
        </MudTooltip>

        @if (AuthService.CurrentUser != null)
        {
            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <ActivatorContent>
                    <MudTooltip Text="@AuthService.CurrentUser.UserName">
                        <MudIconButton Color="Color.Inherit">
                            @if (AuthService.CurrentUser.ProfilePictureUrl != null)
                            {
                                <MudAvatar Style="width: 32px; height: 32px;">
                                    <MudImage Src="@AuthService.CurrentUser.ProfilePictureUrl" Style="width: 100%; height: 100%; object-fit: cover;"/>
                                </MudAvatar>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.AccountCircle"/>
                            }
                        </MudIconButton>
                    </MudTooltip>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Disabled="true">
                        <MudText Typo="Typo.body2" Style="opacity: 0.7;">Signed in as <strong>@AuthService.CurrentUser.UserName</strong></MudText>
                    </MudMenuItem>
                    <MudDivider/>
                    <MudMenuItem Icon="@Icons.Material.Filled.ManageAccounts" Href="/profile">Profile</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="SignOut">Sign Out</MudMenuItem>
                </ChildContent>
            </MudMenu>
        }
        else
        {
            <MudTooltip Text="Sign In">
                <MudIconButton Icon="@Icons.Material.Outlined.AccountCircle" Color="Color.Inherit" OnClick="OpenLoginDialog"/>
            </MudTooltip>
        }
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu/>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>


@code {

    private bool _drawerOpen = true;
    private bool _sessionRestored = false;

    protected override void OnInitialized()
    {
        ThemeService.OnChange += OnThemeChanged;
        AuthService.OnChange += OnAuthChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var darkMode = await LocalStorage.GetAsync<bool>("darkMode");
                if (darkMode.Success)
                    ThemeService.SetDarkMode(darkMode.Value);

                var userId = await LocalStorage.GetAsync<int>("userId");
                if (userId.Success)
                {
                    AuthService.RestoreUser(userId.Value);
                    var color = AuthService.CurrentUser?.PrimaryColor ?? ThemeService.DefaultPrimaryColor;
                    ThemeService.SetPrimaryColor(color);
                }
            }
            catch { /* storage unavailable or tampered */ }

            _sessionRestored = true;
            StateHasChanged();
        }
    }

    private async void OnThemeChanged()
    {
        try { await LocalStorage.SetAsync("darkMode", ThemeService.IsDarkMode); }
        catch { /* storage unavailable */ }
        StateHasChanged();
    }

    private async void OnAuthChanged()
    {
        try
        {
            if (AuthService.CurrentUser != null)
            {
                await LocalStorage.SetAsync("userId", AuthService.CurrentUser.UserId);
                ThemeService.SetPrimaryColor(AuthService.CurrentUser.PrimaryColor ?? ThemeService.DefaultPrimaryColor);
            }
            else
            {
                await LocalStorage.DeleteAsync("userId");
                ThemeService.SetPrimaryColor(ThemeService.DefaultPrimaryColor);
            }
        }
        catch { /* storage unavailable */ }

        StateHasChanged();
    }

    public void Dispose()
    {
        ThemeService.OnChange -= OnThemeChanged;
        AuthService.OnChange -= OnAuthChanged;
    }

    private Task OpenLoginDialog()
    {
        return DialogService.ShowAsync<LoginDialog>("Login", new DialogOptions
        {
            CloseOnEscapeKey = true,
            BackdropClick = true,
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true
        });
    }

    private async Task SignOut()
    {
        AuthService.Logout();
    }
}
