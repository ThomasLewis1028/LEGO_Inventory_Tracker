@inherits LayoutComponentBase
@using Color = MudBlazor.Color
@inject ThemeService ThemeService
@implements IDisposable

<MudThemeProvider Theme="ThemeService.Theme" IsDarkMode="@ThemeService.IsDarkMode"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Elevation="2">
        <MudLink Href="/" Typo="Typo.h6" Color="Color.Inherit" Style="font-weight: 700; letter-spacing: 0.04em; text-decoration: none;">LEGO Inventory</MudLink>
        <MudSpacer/>
        <MudTooltip Text="@(ThemeService.IsDarkMode ? "Light Mode" : "Dark Mode")">
            <MudIconButton Icon="@(ThemeService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" OnClick="@ThemeService.ToggleDarkMode"/>
        </MudTooltip>
    </MudAppBar>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        ThemeService.OnChange -= StateHasChanged;
    }
}
